POSTGRES_USER=admin-dev
POSTGRES_PASSWORD=secret-dev
POSTGRES_DB=vending-dev
POSTGRES_PORT=5433
POSTGRES_HOST=localhost
DATABASE_URL=postgres://admin-dev:secret-dev@localhost:5433/vending-dev?sslmode=disable

# We're using caddy for both front dev and prod now so this works
# This is where the BROWSER goes (Caddy)
VITE_API_URL=http://localhost:8081/api

# This is where the GO SERVER actually lives
ECHO_PORT=8080
ECHO_LOG_LEVEL=debug

# These point to where the services are running on your Mac
BACKEND_HOST=host.docker.internal:8080
FRONTEND_HOST=host.docker.internal:5173