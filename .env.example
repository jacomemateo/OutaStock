# =============================================================================
# APP DATABASE (your backend)
# =============================================================================
APP_DB_USER=admin
APP_DB_PASSWORD=secret
APP_DB_NAME=vending
APP_DB_HOST=db
APP_DB_PORT=5432

# =============================================================================
# BACKEND
# =============================================================================
ECHO_PORT=8080
ECHO_LOG_LEVEL=info

# =============================================================================
# FRONTEND
# =============================================================================
API_BASE_URL=/api

# =============================================================================
# INTERNAL SERVICE HOSTS (used by Caddy)
# =============================================================================
BACKEND_HOST=backend:8080
FRONTEND_HOST=frontend:3000

# =============================================================================
# ZITADEL (LOCAL DEV SAFE DEFAULTS)
# =============================================================================
ZITADEL_DOMAIN=auth.localhost
ZITADEL_EXTERNALPORT=80
ZITADEL_EXTERNALSECURE=false
ZITADEL_PUBLIC_SCHEME=http

ZITADEL_MASTERKEY=MasterkeyNeedsToHave32Characters
LOGIN_CLIENT_PAT_EXPIRATION=2099-01-01T00:00:00Z

ZITADEL_VERSION=v4.11.0

# =============================================================================
# ZITADEL DATABASE (SEPARATE)
# =============================================================================
ZITADEL_DB_NAME=zitadel
ZITADEL_DB_USER=postgres
ZITADEL_DB_PASSWORD=postgres

POSTGRES_IMAGE=postgres:17.2-alpine

# =============================================================================
# ZITADEL AUTH SETTINGS
# =============================================================================
ZITADEL_ISSUER=http://auth.localhost
ZITADEL_CLIENT_ID=bootstrap-pending
ZITADEL_ORGANIZATION_ID=bootstrap-pending
ZITADEL_REDIRECT_URI=http://localhost/auth/callback
ZITADEL_POST_LOGOUT_REDIRECT_URI=http://localhost/
ZITADEL_SCOPE=openid profile email
ZITADEL_AUTH_ENABLED=false

# =============================================================================
# OPTIONAL SERVICES
# =============================================================================
REDIS_IMAGE=redis:7.4.2-alpine
OTEL_COLLECTOR_IMAGE=otel/opentelemetry-collector-contrib:0.114.0

# =============================================================================
# LOGGING / FEATURES, off now
# =============================================================================
ZITADEL_ACCESS_LOG_STDOUT_ENABLED=true

ZITADEL_CACHES_CONNECTORS_REDIS_ENABLED=false
ZITADEL_CACHES_CONNECTORS_REDIS_URL=redis://redis:6379/0

ZITADEL_INSTRUMENTATION_SERVICENAME=zitadel-api
ZITADEL_INSTRUMENTATION_TRACE_EXPORTER_TYPE=none
ZITADEL_INSTRUMENTATION_TRACE_EXPORTER_ENDPOINT=otel-collector:4317
ZITADEL_INSTRUMENTATION_TRACE_EXPORTER_INSECURE=true

LOGIN_OTEL_SERVICE_NAME=zitadel-login
LOGIN_OTEL_EXPORTER_OTLP_ENDPOINT=
LOGIN_OTEL_EXPORTER_OTLP_PROTOCOL=grpc