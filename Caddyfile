# Caddyfile
{
	# Global email for SSL certs
	email jacome.mateo@icloud.com
}

:80 {
	encode gzip zstd

	# Add basic security headers (Good practice to start now)
	header {
		# Enable HSTS (Force HTTPS) - Only activates when you use a real domain
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		# Prevent clickjacking
		X-Frame-Options "SAMEORIGIN"
		# Prevent MIME sniffing
		X-Content-Type-Options "nosniff"
	}

	handle /api/* {
		reverse_proxy {$BACKEND_HOST}
	}

	handle {
		reverse_proxy {$FRONTEND_HOST}
	}
}

api.localhost:80 {
	# 1. Route API calls on THIS subdomain to the backend
	handle /api/* {
		reverse_proxy {$BACKEND_HOST}
	}

	# 2. Everything else is the Swagger UI
	handle {
		reverse_proxy swagger:8080
	}
}

# =============================================================================
# ZITADEL AUTH SERVER
#
# Two important things happening here:
#
# 1. The login UI (/ui/v2/login/*) is a plain Next.js app — normal HTTP proxy.
#
# 2. Everything else goes to zitadel-api, which speaks HTTP/2 (gRPC) internally.
#    Caddy handles HTTPS externally but connects to Zitadel using h2c
#    (HTTP/2 cleartext) since there's no TLS between containers.
# =============================================================================
{$ZITADEL_DOMAIN} {
    encode gzip zstd

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options "nosniff"
    }

    # Redirect bare root to the login page
    redir / /ui/v2/login/ 302

    # Login UI — plain HTTP/1.1 is fine for the Next.js frontend
    handle /ui/v2/login* {
        reverse_proxy zitadel-login:3000
    }

    # Everything else (OIDC endpoints, gRPC, admin console, etc.) → Zitadel API
    # Must use h2c because Zitadel's API server requires HTTP/2
    handle {
        reverse_proxy zitadel-api:8080 {
            transport http {
                versions h2c
            }
        }
    }
}